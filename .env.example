# Example environment variables for EauSure Auth API

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/eausure_auth

# JWT secret used to sign and verify access tokens
JWT_SECRET=replace_with_a_strong_secret

# Local server port
PORT=3000

# Public base URL of this auth API
API_URL=http://localhost:3000

# Frontend base URL used for OAuth callback redirections
FRONTEND_URL=http://localhost:8081

# OAuth providers Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
